---
import Layout from "../layouts/Layout.astro";
const title = "Hale biurowe - wykończenia pod klucz | Novoterm Budownictwo";
const description = "Kompetencja flagowa Novoterm: wykończenia hal biurowych i powierzchni biurowych w obiektach przemysłowych. Zabudowy, sufity, posadzki, instalacje - pod klucz.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Specjalizacje</span> <span class="sep">/</span> <span>Hale biurowe</span></nav>
        <h1 data-hero>Hale biurowe. Nasza specjalność.</h1>
        <p class="lead" data-hero>Wykończenia powierzchni biurowych w obiektach halowych - od open space przy halach produkcyjnych po samodzielne budynki biurowe.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap--narrow">
        <div class="section-head">
          <span class="label" data-reveal>Zakres prac</span>
          <h2 class="h-lg" data-reveal>Kompletna powierzchnia biurowa</h2>
        </div>
        <div class="scope-list">
          <div class="scope-item" data-reveal><span class="no">01</span><span class="name">Ścianki działowe i zabudowy g-k</span><span class="tag">Sucha zabudowa</span></div>
          <div class="scope-item" data-reveal><span class="no">02</span><span class="name">Sufity podwieszane - g-k, kasetonowe OWA, rastrowe</span><span class="tag">Akustyka</span></div>
          <div class="scope-item" data-reveal><span class="no">03</span><span class="name">Posadzki - wykładziny, panele, żywice</span><span class="tag">Wykończenia</span></div>
          <div class="scope-item" data-reveal><span class="no">04</span><span class="name">Szpachlowanie maszynowe i malowanie</span><span class="tag">Wykończenia</span></div>
          <div class="scope-item" data-reveal><span class="no">05</span><span class="name">Instalacje elektryczne i teletechniczne</span><span class="tag">Branże</span></div>
          <div class="scope-item" data-reveal><span class="no">06</span><span class="name">Węzły sanitarne i socjalne</span><span class="tag">Branże</span></div>
          <div class="scope-item" data-reveal><span class="no">07</span><span class="name">Izolacje termiczne i akustyczne przegród</span><span class="tag">PUR / wełna</span></div>
        </div>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap two-col">
        <div class="col-head">
          <span class="label" data-reveal>Case study</span>
          <h2 class="h-lg" data-reveal>Zaplecze biurowe hali produkcyjnej - Września</h2>
          <p class="lead" data-reveal>860 m² powierzchni biurowo-socjalnej: od stanu surowego do przekazania najemcy w 11 tygodni.</p>
        </div>
        <table class="spec-table" data-reveal>
          <tr><th>Powierzchnia</th><td>860 m² - biura, sale konferencyjne, zaplecze socjalne</td></tr>
          <tr><th>Zakres</th><td>Kompletne wykończenie pod klucz: zabudowy g-k, sufity kasetonowe, posadzki, elektryka, sanitariaty</td></tr>
          <tr><th>Czas realizacji</th><td>11 tygodni - zgodnie z harmonogramem kontraktowym</td></tr>
          <tr><th>Tryb</th><td>Prace prowadzone równolegle z rozruchem części produkcyjnej hali</td></tr>
          <tr><th>Wynik</th><td>Odbiór bez uwag, powierzchnia przekazana najemcy w terminie</td></tr>
        </table>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Wykańczasz zaplecze biurowe hali? Jesteśmy od tego.</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
