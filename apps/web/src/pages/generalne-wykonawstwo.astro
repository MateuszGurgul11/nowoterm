---
import Layout from "../layouts/Layout.astro";
const title = "Generalne wykonawstwo - budynki usługowe 1000–2000 m² | Novoterm Budownictwo";
const description = "Generalne wykonawstwo budynków usługowych 1000–2000 m² pod klucz. Jeden wykonawca, pełna odpowiedzialność: harmonogram, budżet, podwykonawcy, odbiór.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Generalne wykonawstwo</span></nav>
        <h1 data-hero>Budynki usługowe 1000–2000 m² pod klucz</h1>
        <p class="lead" data-hero>Jeden podmiot odpowiedzialny za całość: koordynację branż, harmonogram, budżet i jakość. Ty rozmawiasz z jednym kierownikiem projektu - my pilnujemy reszty.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap two-col">
        <div class="col-head">
          <span class="label" data-reveal>Zakres</span>
          <h2 class="h-lg" data-reveal>Co bierzemy na siebie</h2>
          <p class="lead" data-reveal>Optymalny zakres naszych kontraktów to obiekty usługowe i biurowe 1000–2000 m² - dokładnie w skali, w której jesteśmy najbardziej konkurencyjni.</p>
        </div>
        <ul class="check-list">
          <li data-reveal><span><b>Koordynacja wszystkich branż</b> - konstrukcja, elektryka, wod-kan, HVAC, wykończenia pod jednym nadzorem.</span></li>
          <li data-reveal><span><b>Harmonogram rzeczowo-finansowy</b> - kamienie milowe płatności powiązane z realnym postępem prac.</span></li>
          <li data-reveal><span><b>Zarządzanie podwykonawcami</b> - weryfikacja, umowy, rozliczenia i odpowiedzialność po naszej stronie.</span></li>
          <li data-reveal><span><b>Nadzór jakości i dokumentacja</b> - dziennik budowy, raporty tygodniowe, dokumentacja powykonawcza.</span></li>
          <li data-reveal><span><b>Stany: deweloperski lub pod klucz</b> - zakres dopasowany do modelu inwestycji i najemców.</span></li>
          <li data-reveal><span><b>Gwarancja i serwis</b> - jasne warunki gwarancji na całość prac, jeden punkt zgłoszeń.</span></li>
        </ul>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Etapy współpracy</span>
          <h2 class="h-lg" data-reveal>Projekt krok po kroku</h2>
        </div>
        <div class="steps">
          <div class="step" data-reveal><span class="step-no">01</span><h3>Brief i wycena</h3><p>Analiza dokumentacji, wizja lokalna, kosztorys ofertowy z podziałem na branże.</p></div>
          <div class="step" data-reveal><span class="step-no">02</span><h3>Kontrakt</h3><p>Umowa GW z harmonogramem i zabezpieczeniami dla inwestora.</p></div>
          <div class="step" data-reveal><span class="step-no">03</span><h3>Mobilizacja</h3><p>Przejęcie placu budowy, plan BIOZ, kontraktacja podwykonawców.</p></div>
          <div class="step" data-reveal><span class="step-no">04</span><h3>Realizacja</h3><p>Prace budowlane i wykończeniowe z cotygodniowym raportowaniem.</p></div>
          <div class="step" data-reveal><span class="step-no">05</span><h3>Odbiór</h3><p>Odbiory branżowe i końcowy, dokumentacja, obsługa gwarancyjna.</p></div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Planujesz budynek usługowy? Policzmy go razem.</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
