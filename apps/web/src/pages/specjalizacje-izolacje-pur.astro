---
import Layout from "../layouts/Layout.astro";
const title = "Izolacje natryskowe PUR — parametry i energooszczędność | Novoterm";
const description = "Natrysk piany poliuretanowej PUR: dachy i ściany hal, stropy, poddasza. Lambda od 0,022 W/mK, izolacja bezspoinowa, szybka aplikacja. Wielkopolska.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Specjalizacje</span> <span class="sep">/</span> <span>Izolacje PUR</span></nav>
        <h1 data-hero>Izolacje natryskowe pianą PUR</h1>
        <p class="lead" data-hero>Bezspoinowa termoizolacja o najwyższych parametrach na rynku. Własne agregaty, certyfikowane systemy, aplikacja do 800 m² dziennie.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap--narrow">
        <div class="section-head">
          <span class="label" data-reveal>Parametry techniczne</span>
          <h2 class="h-lg" data-reveal>Dane, nie obietnice</h2>
        </div>
        <table class="spec-table" data-reveal>
          <tr><th>Współczynnik λ</th><td>od 0,022 W/(m·K) — piana zamkniętokomórkowa; jedna z najniższych wartości wśród izolacji budowlanych</td></tr>
          <tr><th>Struktura</th><td>Bezspoinowa — brak mostków termicznych na łączeniach, szczelne przyleganie do podłoża</td></tr>
          <tr><th>Zastosowania</th><td>Dachy i ściany hal, stropy, poddasza użytkowe, fundamenty, chłodnie</td></tr>
          <tr><th>Tempo aplikacji</th><td>do 800 m² dziennie — minimalny czas przestoju obiektu</td></tr>
          <tr><th>Przyczepność</th><td>Blacha trapezowa, beton, drewno, mury — bez kołkowania i klejenia</td></tr>
          <tr><th>Paroprzepuszczalność</th><td>Piany otwartokomórkowe dla przegród wymagających dyfuzji pary wodnej</td></tr>
        </table>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Przewagi</span>
          <h2 class="h-lg" data-reveal>Dlaczego PUR wygrywa w obiektach przemysłowych</h2>
        </div>
        <div class="info-cards">
          <div class="info-card" data-reveal><span class="ic-label">Energia</span><h3>Do 40% niższe koszty ogrzewania</h3><p>Niska lambda i brak mostków termicznych przekładają się bezpośrednio na rachunki za energię.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Czas</span><h3>Izolacja hali w dni, nie tygodnie</h3><p>Natrysk eliminuje cięcie, mocowanie i spoinowanie płyt — hala wraca do pracy szybciej.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Trwałość</span><h3>Stabilność parametrów przez dekady</h3><p>Piana nie osiada i nie przemieszcza się jak wełna — parametry cieplne bez degradacji.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Szczelność</span><h3>Uszczelnienie i izolacja w jednym</h3><p>Warstwa PUR domyka nieszczelności powietrzne przegrody, ograniczając straty wentylacyjne.</p></div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Policz oszczędności energii dla swojego obiektu</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
