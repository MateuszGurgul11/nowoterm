---
import Layout from "../layouts/Layout.astro";
const title = "O firmie — Novoterm Budownictwo | Generalny wykonawca Wielkopolska";
const description = "Novoterm Budownictwo — średniej wielkości generalny wykonawca wykończeń obiektów biurowych i przemysłowych. Własne zespoły, zaplecze techniczne, cała Wielkopolska.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Firma</span></nav>
        <h1 data-hero>Solidny partner Twojej inwestycji</h1>
        <p class="lead" data-hero>Średniej wielkości generalny wykonawca z Wielkopolski — dość duży, by wziąć pełną odpowiedzialność za projekt, dość zwinny, by decyzje zapadały w godziny.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap two-col">
        <div class="col-head">
          <span class="label" data-reveal>Skala działania</span>
          <h2 class="h-lg" data-reveal>Wyspecjalizowani, nie rozproszeni</h2>
        </div>
        <div class="col-body">
          <p data-reveal>Skupiamy kompetencje tam, gdzie dowozimy najwięcej wartości: wykończenia obiektów biurowych i przemysłowych oraz budynki usługowe do 2000 m² pod klucz.</p>
          <p data-reveal>85% naszych realizacji to projekty B2B — dla inwestorów, deweloperów i zarządców nieruchomości. Znamy realia przetargów, harmonogramów najmu i presji terminów.</p>
        </div>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Zaplecze</span>
          <h2 class="h-lg" data-reveal>Zespół i wyposażenie</h2>
        </div>
        <div class="info-cards">
          <div class="info-card" data-reveal>
            <span class="ic-label">Zespół</span>
            <h3>Własne brygady wykonawcze</h3>
            <p>Stałe zespoły suchej zabudowy i natrysku PUR oraz sprawdzona sieć podwykonawców branżowych — elektryka, HVAC, posadzki. Kierownik robót prowadzi projekt od pierwszego dnia do odbioru.</p>
          </div>
          <div class="info-card" data-reveal>
            <span class="ic-label">Zaplecze techniczne</span>
            <h3>Sprzęt do zadań przemysłowych</h3>
            <p>Agregaty do natrysku piany PUR, szpachlowania i tynków maszynowych, podnośniki i rusztowania systemowe — park maszynowy pod własną kontrolą.</p>
          </div>
          <div class="info-card" data-reveal>
            <span class="ic-label">Obszar działania</span>
            <h3>Cała Wielkopolska</h3>
            <p>Września, Poznań, Gniezno, Konin, Środa Wlkp. i okolice. Przy większych kontraktach realizujemy projekty również poza województwem.</p>
          </div>
          <div class="info-card" data-reveal>
            <span class="ic-label">Dla kogo</span>
            <h3>Inwestorzy, deweloperzy, zarządcy</h3>
            <p>Komunikacja i standard dokumentacji dopasowane do wymagań rynku komercyjnego — od pierwszej wyceny po dokumentację powykonawczą.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap--narrow">
        <div class="section-head">
          <span class="label" data-reveal>Liczby</span>
          <h2 class="h-lg" data-reveal>Novoterm w liczbach</h2>
        </div>
        <table class="spec-table" data-reveal>
          <tr><th>Powierzchnie wykończone</th><td>38 500+ m² — biura, hale, obiekty usługowe</td></tr>
          <tr><th>Zrealizowane projekty</th><td>140+ zakończonych zleceń, w tym realizacje pod klucz</td></tr>
          <tr><th>Doświadczenie</th><td>12 lat na rynku budowlanym</td></tr>
          <tr><th>Profil klientów</th><td>85% B2B — inwestorzy komercyjni, deweloperzy, zarządcy nieruchomości</td></tr>
          <tr><th>Zakres kontraktów</th><td>Budynki usługowe 1000–2000 m² w generalnym wykonawstwie</td></tr>
        </table>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Sprawdź, jak pracujemy przy projektach takich jak Twój</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
