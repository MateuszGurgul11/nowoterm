---
import Layout from "../layouts/Layout.astro";
const title = "Sucha zabudowa - ścianki, sufity podwieszane, zabudowy g-k | Novoterm";
const description = "Systemowa sucha zabudowa: ścianki działowe, sufity podwieszane g-k i kasetonowe, zabudowa poddaszy, sufity napinane, szpachlowanie maszynowe.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Specjalizacje</span> <span class="sep">/</span> <span>Sucha zabudowa</span></nav>
        <h1 data-hero>Sucha zabudowa systemowa</h1>
        <p class="lead" data-hero>Najszybsza droga od otwartej przestrzeni do gotowych pomieszczeń. Własne zespoły monterskie, systemy renomowanych producentów.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap--narrow">
        <div class="section-head">
          <span class="label" data-reveal>Zakres prac</span>
          <h2 class="h-lg" data-reveal>Pełen zakres suchej zabudowy</h2>
        </div>
        <div class="scope-list">
          <div class="scope-item" data-reveal><span class="no">01</span><span class="name">Sufity podwieszane g-k</span><span class="tag">Systemy</span></div>
          <div class="scope-item" data-reveal><span class="no">02</span><span class="name">Sufity kasetonowe OWA / rastrowe / ażurowe</span><span class="tag">Akustyka</span></div>
          <div class="scope-item" data-reveal><span class="no">03</span><span class="name">Ścianki i ściany działowe</span><span class="tag">Aranżacja</span></div>
          <div class="scope-item" data-reveal><span class="no">04</span><span class="name">Zabudowa poddaszy</span><span class="tag">Adaptacje</span></div>
          <div class="scope-item" data-reveal><span class="no">05</span><span class="name">Sufity napinane</span><span class="tag">Design</span></div>
          <div class="scope-item" data-reveal><span class="no">06</span><span class="name">Szpachlowanie maszynowe</span><span class="tag">Duże metraże</span></div>
          <div class="scope-item" data-reveal><span class="no">07</span><span class="name">Zabudowy akustyczne i ppoż.</span><span class="tag">Certyfikaty</span></div>
        </div>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Przewagi</span>
          <h2 class="h-lg" data-reveal>Dlaczego sucha zabudowa</h2>
        </div>
        <div class="steps" style="grid-template-columns:repeat(3,1fr)">
          <div class="step" data-reveal><span class="step-no">01</span><h3>Szybkość montażu</h3><p>Technologia sucha - bez przerw na wiązanie i schnięcie. Pomieszczenia gotowe w dni.</p></div>
          <div class="step" data-reveal><span class="step-no">02</span><h3>Elastyczna aranżacja</h3><p>Łatwe zmiany układu przestrzeni pod kolejnych najemców - bez prac mokrych.</p></div>
          <div class="step" data-reveal><span class="step-no">03</span><h3>Parametry na certyfikat</h3><p>Odporność ogniowa i izolacyjność akustyczna potwierdzone aprobatami.</p></div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Aranżujesz powierzchnię? Prześlij rzut - wycenimy zabudowę.</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
