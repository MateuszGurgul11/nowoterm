---
import Layout from "../layouts/Layout.astro";
import { getContentSnapshot } from "../lib/cms";

const title = "Novoterm Budownictwo - Generalny wykonawca wykończeń obiektów biurowych i przemysłowych | Wielkopolska";
const description = "Generalny wykonawca prac wykończeniowych obiektów biurowych i przemysłowych. Hale biurowe, budynki usługowe do 2000 m² pod klucz, izolacje PUR, sucha zabudowa. Wielkopolska - Września, Poznań.";

const { projects } = await getContentSnapshot();
const featured = projects.filter((p) => p.featured).slice(0, 3);

function formatArea(area: number | null | undefined): string | null {
  if (area == null) return null;
  return `${Number(area).toLocaleString("pl-PL")} m²`;
}
---

<Layout {title} {description} solidHeader={false}>
<main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-media" aria-hidden="true">
        <video
          class="hero-video"
          muted
          playsinline
          preload="auto"
        >
          <source src="/assets/panorama-miasta.mp4" type="video/mp4" />
        </video>
      </div>

      <p class="hero-note" data-hero>
        Generalny wykonawca wykończeń obiektów komercyjnych.<br>
        <b>Hale biurowe to nasza specjalność.</b>
      </p>

      <div class="hero-center">
        <div class="hero-mark" data-hero>
          <h1 class="hero-logo">
            <img
              src="/assets/logo/2.png"
              alt="Novoterm Budownictwo"
              width="1069"
              height="834"
            />
          </h1>
        </div>
        <p class="hero-tag" data-hero>
          Wykończenia obiektów biurowych i przemysłowych.
          Budynki usługowe do 2000 m² - pod klucz.
        </p>
      </div>

      <a class="hero-scroll" href="#oferta" aria-label="Przewiń do oferty">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 4.5 L7 9.5 L12 4.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
        </svg>
      </a>
    </section>

    <!-- STATEMENT -->
    <section class="section">
      <div class="wrap--narrow statement">
        <span class="label" data-reveal>Novoterm Budownictwo</span>
        <span class="rule" data-reveal></span>
        <h2 class="h-xl" data-reveal>Solidny partner Twojej inwestycji</h2>
        <p class="lead" data-reveal>
          Jesteśmy średniej wielkości generalnym wykonawcą - na tyle dużym, by prowadzić
          kompleksowe projekty z pełną odpowiedzialnością, i na tyle elastycznym,
          by decyzje zapadały w godziny, nie tygodnie.
        </p>
      </div>
    </section>

    <!-- OFERTA / 3 FILARY -->
    <section class="section section--soft" id="oferta">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Oferta</span>
          <h2 class="h-lg" data-reveal>Budujemy dla biznesu</h2>
        </div>
        <div class="pillars">
          <article class="pillar" data-reveal>
            <span class="pillar-no">01</span>
            <h3>Generalne wykonawstwo</h3>
            <p>Budynki usługowe 1000–2000 m² realizowane pod klucz. Jeden punkt kontaktu
               i pełna odpowiedzialność za termin, budżet i podwykonawców.</p>
            <a class="link-more" href="/generalne-wykonawstwo">Więcej</a>
          </article>
          <article class="pillar" data-reveal>
            <span class="pillar-no">02</span>
            <h3>Hale biurowe</h3>
            <p>Nasza kompetencja flagowa - wykończenia powierzchni biurowych w obiektach
               halowych i przemysłowych. Od stanu surowego po przekazanie najemcy.</p>
            <a class="link-more" href="/specjalizacje-hale-biurowe">Więcej</a>
          </article>
          <article class="pillar" data-reveal>
            <span class="pillar-no">03</span>
            <h3>Specjalizacje techniczne</h3>
            <p>Izolacje natryskowe pianą PUR oraz systemowa sucha zabudowa -
               własne zespoły wykonawcze i parametry potwierdzone kartami technicznymi.</p>
            <a class="link-more" href="/specjalizacje-izolacje-pur">Więcej</a>
          </article>
        </div>
      </div>
    </section>

    <!-- LICZBY -->
    <section class="stats-band">
      <div class="wrap">
        <span class="label" data-reveal>Novoterm w liczbach</span>
        <h2 data-reveal>Doświadczenie, które można zmierzyć</h2>
        <div class="stats">
          <div class="stat" data-reveal>
            <span class="stat-val"><span data-count="38500">0</span><span class="u">m²</span></span>
            <span class="stat-key">wykończonych powierzchni</span>
          </div>
          <div class="stat" data-reveal>
            <span class="stat-val"><span data-count="140">0</span><span class="u">+</span></span>
            <span class="stat-key">zrealizowanych projektów</span>
          </div>
          <div class="stat" data-reveal>
            <span class="stat-val"><span data-count="12">0</span></span>
            <span class="stat-key">lat w branży budowlanej</span>
          </div>
          <div class="stat" data-reveal>
            <span class="stat-val"><span data-count="2000">0</span><span class="u">m²</span></span>
            <span class="stat-key">budynki usługowe pod klucz</span>
          </div>
        </div>
      </div>
    </section>

    <!-- O NAS -->
    <section class="section">
      <div class="wrap two-col">
        <div class="col-head">
          <span class="label" data-reveal>O nas</span>
          <h2 class="h-lg" data-reveal>Kompetentny partner budowlany</h2>
          <div class="media-ph" aria-hidden="true" data-reveal><span>Zdjęcie</span></div>
        </div>
        <div class="col-body">
          <p data-reveal>
            Specjalizujemy się w pracach wykończeniowych obiektów biurowych
            i przemysłowych. 85% naszych realizacji to projekty B2B - znamy realia
            przetargów, harmonogramów najmu i presji terminów.
          </p>
          <p data-reveal>
            Własne zespoły suchej zabudowy i natrysku PUR, sprawdzona sieć podwykonawców
            branżowych oraz kierownik projektu prowadzący inwestycję od pierwszego dnia
            do odbioru. Działamy na terenie całej Wielkopolski.
          </p>
          <a class="btn" href="/o-firmie" data-reveal>Poznaj nas bliżej</a>
        </div>
      </div>
    </section>

    <!-- ATUTY -->
    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Nasze atuty</span>
          <h2 class="h-lg" data-reveal>Co nas wyróżnia</h2>
        </div>
        <div class="values">
          <div class="value" data-reveal>
            <h3>Terminowość</h3>
            <p>Harmonogram rzeczowo-finansowy z kamieniami milowymi - postęp prac widać w zestawieniu, nie w opowieściach.</p>
          </div>
          <div class="value" data-reveal>
            <h3>Jakość</h3>
            <p>Systemy renomowanych producentów, odbiory robót dokumentowane protokołami na każdym etapie.</p>
          </div>
          <div class="value" data-reveal>
            <h3>Jeden punkt kontaktu</h3>
            <p>Kierownik projektu odpowiedzialny za całość - od wyceny po dokumentację powykonawczą.</p>
          </div>
          <div class="value" data-reveal>
            <h3>Własne zespoły</h3>
            <p>Sucha zabudowa i natrysk PUR bez pośredników - pełna kontrola jakości i tempa prac.</p>
          </div>
          <div class="value" data-reveal>
            <h3>Przewidywalny budżet</h3>
            <p>Roboty dodatkowe wyłącznie po pisemnym zatwierdzeniu wyceny. Zero niespodzianek w rozliczeniach.</p>
          </div>
          <div class="value" data-reveal>
            <h3>Gwarancja</h3>
            <p>Jasne warunki gwarancji na całość prac i jeden punkt zgłoszeń serwisowych po odbiorze.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- REALIZACJE - skrót -->
    <section class="section">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Realizacje</span>
          <h2 class="h-lg" data-reveal>Wybrane projekty</h2>
        </div>
        <div class="works">
          {
            featured.map((project) => (
              <article class="work" data-reveal>
                <a href={`/realizacje/${project.slug}`} aria-label={`Zobacz realizację: ${project.title}`}>
                  <div class="work-media">
                    <svg viewBox="0 0 400 300" aria-hidden="true">
                      <path d="M60 220 V110 H340 V220 Z" stroke="#9aa0a8" stroke-width="1.2" fill="none" />
                      <path d="M60 165 H340" stroke="#ff914d" stroke-width="1.6" />
                    </svg>
                  </div>
                  <div class="work-body">
                    <span class="work-cat">{project.category}</span>
                    <h3>{project.title}</h3>
                    <div class="work-meta">
                      {formatArea(project.area_m2) && <span>{formatArea(project.area_m2)}</span>}
                      {project.duration && <span>{project.duration}</span>}
                    </div>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
        <div style="text-align:center; margin-top: clamp(44px, 5vw, 64px)" data-reveal>
          <a class="btn" href="/realizacje">Zobacz wszystkie</a>
        </div>
      </div>
    </section>

    <!-- PROCES -->
    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Proces współpracy</span>
          <h2 class="h-lg" data-reveal>Od zapytania do odbioru</h2>
        </div>
        <div class="steps">
          <div class="step" data-reveal>
            <span class="step-no">01</span>
            <h3>Wycena</h3>
            <p>Analiza dokumentacji lub wizja lokalna. Oferta w 5 dni roboczych.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-no">02</span>
            <h3>Harmonogram</h3>
            <p>Umowa z harmonogramem rzeczowo-finansowym i kamieniami milowymi.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-no">03</span>
            <h3>Realizacja</h3>
            <p>Własne zespoły i sprawdzeni podwykonawcy pod jednym nadzorem.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-no">04</span>
            <h3>Nadzór</h3>
            <p>Cotygodniowe raporty postępu, kontrola jakości i budżetu.</p>
          </div>
          <div class="step" data-reveal>
            <span class="step-no">05</span>
            <h3>Odbiór</h3>
            <p>Dokumentacja powykonawcza i gwarancja na wykonane prace.</p>
          </div>
        </div>
        <div style="text-align:center; margin-top: clamp(44px, 5vw, 64px)" data-reveal>
          <a class="link-more" href="/proces">Pełny proces dla inwestorów</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Masz projekt biurowy lub przemysłowy do wykończenia?</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
