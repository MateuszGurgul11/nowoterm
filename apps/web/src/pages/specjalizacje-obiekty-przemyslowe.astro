---
import Layout from "../layouts/Layout.astro";
const title = "Obiekty przemysłowe - wykończenia hal produkcyjnych i magazynów | Novoterm";
const description = "Wykończenia obiektów przemysłowych: hale produkcyjne, magazyny, zaplecza socjalne. Izolacje PUR, zabudowy, posadzki - praca w reżimie działającego zakładu.";
---

<Layout {title} {description} solidHeader={true}>
<main>
    <section class="page-hero">
      <div class="wrap">
        <nav class="crumbs" aria-label="Okruszki"><a href="/">Novoterm</a> <span class="sep">/</span> <span>Specjalizacje</span> <span class="sep">/</span> <span>Obiekty przemysłowe</span></nav>
        <h1 data-hero>Obiekty produkcyjne i magazynowe</h1>
        <p class="lead" data-hero>Rozumiemy specyfikę pracy w działającym zakładzie: reżim BHP, okna technologiczne, brak przestojów produkcji.</p>
        <span class="rule" data-hero></span>
      </div>
    </section>

    <section class="section">
      <div class="wrap two-col">
        <div class="col-head">
          <span class="label" data-reveal>Zakres</span>
          <h2 class="h-lg" data-reveal>Co wykonujemy w obiektach przemysłowych</h2>
        </div>
        <ul class="check-list">
          <li data-reveal><span><b>Izolacje termiczne hal</b> - natrysk piany PUR na dachy, ściany i stropy, docieplenia wełną mineralną.</span></li>
          <li data-reveal><span><b>Zaplecza socjalno-biurowe</b> - wykończenia szatni, stołówek, biur mistrzów i części administracyjnych.</span></li>
          <li data-reveal><span><b>Ściany i sufity systemowe</b> - zabudowy g-k o podwyższonej odporności, sufity techniczne z rewizjami.</span></li>
          <li data-reveal><span><b>Tynki i szpachlowanie maszynowe</b> - duże powierzchnie w krótkich oknach czasowych.</span></li>
          <li data-reveal><span><b>Remonty i adaptacje</b> - przebudowy istniejących obiektów bez zatrzymywania produkcji.</span></li>
          <li data-reveal><span><b>Konstrukcje stalowe uzupełniające</b> - antresole, podesty, wygrodzenia techniczne.</span></li>
        </ul>
      </div>
    </section>

    <section class="section section--soft">
      <div class="wrap">
        <div class="section-head">
          <span class="label" data-reveal>Warunki pracy</span>
          <h2 class="h-lg" data-reveal>Praca w reżimie zakładu</h2>
        </div>
        <div class="info-cards">
          <div class="info-card" data-reveal><span class="ic-label">Harmonogram</span><h3>Okna technologiczne</h3><p>Prace planujemy pod przestoje, weekendy i zmiany nocne - produkcja idzie dalej.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Bezpieczeństwo</span><h3>Pełny reżim BHP</h3><p>Szkolenia stanowiskowe, wygrodzenia stref, koordynacja ze służbami utrzymania ruchu.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Czystość</span><h3>Strefy odcięte od produkcji</h3><p>Kurtyny pyłowe i osobne ciągi transportowe chronią procesy i towar.</p></div>
          <div class="info-card" data-reveal><span class="ic-label">Rozliczenia</span><h3>Etapowanie prac</h3><p>Zakres dzielony na etapy odbierane osobno - pełna kontrola budżetu.</p></div>
        </div>
      </div>
    </section>

    <section class="cta-band">
      <div class="wrap">
        <span class="label" data-reveal>Kontakt</span>
        <h2 data-reveal>Modernizujesz halę? Ustalmy zakres i okna realizacji.</h2>
        <a class="btn btn--light" href="/kontakt" data-reveal>Zapytanie ofertowe</a>
      </div>
    </section>
  </main>
</Layout>
