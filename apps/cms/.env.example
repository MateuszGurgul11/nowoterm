ENVIRONMENT=development
# Project Settings → Database → Connection string (URI).
# Transaction pooler (port 6543). Replace YOUR_DATABASE_PASSWORD.
# Specjalne znaki w haśle: URL-encode (np. @ → %40).
DATABASE_URL=postgresql+psycopg://postgres.hasyqhncdnpwikxeczib:YOUR_DATABASE_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
SESSION_SECRET=replace-with-at-least-32-random-characters
EXPORT_TOKEN=replace-with-a-long-random-token
VERCEL_DEPLOY_HOOK=
SUPABASE_URL=https://hasyqhncdnpwikxeczib.supabase.co
# Dashboard → Project Settings → API → anon / publishable key
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MEDIA_BUCKET=media
# Logowanie: utwórz użytkownika w Dashboard → Authentication → Users
